{
  "manifest_version": 3,
  "name": "HashCompanion",
  "version": "1.1.1",
  "description": "HashCompanion: a multi-tool extension for Hedera Hashgraph with account management, transactions, and developer utilities.",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/StacksHC.png",
      "48": "icons/StacksHC.png",
      "128": "icons/StacksHC.png"
    }
  },
  "icons": {
    "16": "icons/StacksHC.png",
    "48": "icons/StacksHC.png",
    "128": "icons/StacksHC.png"
  },
  "permissions": ["storage"]
}